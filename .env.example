# ===========================================
# RUX - AI-Powered App Generator
# Environment Configuration
# ===========================================

# ===========================================
# Core Services (Required)
# ===========================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx
SUPABASE_JWT_SECRET=xxxxx
DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DIRECT_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# Auth Providers (comma-separated: github,google)
NEXT_PUBLIC_AUTH_PROVIDERS=github,google

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ===========================================
# AI API Keys (Required - at least xAI)
# ===========================================

# xAI Grok - Primary AI model
XAI_API_KEY=xai-xxxxx

# Anthropic Claude - Premium code generation
CLAUDE_API_KEY=sk-ant-xxxxx

# ===========================================
# Upstash Redis (Required - Rate Limiting)
# ===========================================

UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxx

# ===========================================
# Encryption (Required)
# ===========================================

# Generate with: openssl rand -base64 32
ENCRYPTION_MASTER_KEY=xxxxx
HASH_SALT=xxxxx

# ===========================================
# Stripe (Payments)
# ===========================================

STRIPE_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Stripe Price IDs
STRIPE_PRO_PRICE_ID=price_xxxxx
STRIPE_ELITE_PRICE_ID=price_xxxxx
STRIPE_TOKEN_SMALL_PRICE_ID=price_xxxxx
STRIPE_TOKEN_MEDIUM_PRICE_ID=price_xxxxx
STRIPE_TOKEN_LARGE_PRICE_ID=price_xxxxx
STRIPE_TOKEN_MEGA_PRICE_ID=price_xxxxx

# ===========================================
# Expo / EAS Builds
# ===========================================

EAS_ACCESS_TOKEN=xxxxx
EXPO_PROJECT_ID=xxxxx

# ===========================================
# GitHub OAuth (optional)
# ===========================================

GITHUB_CLIENT_ID=xxxxx
GITHUB_CLIENT_SECRET=xxxxx

# ===========================================
# Storage (Cloudflare R2)
# ===========================================

STORAGE_PROVIDER=r2
STORAGE_BUCKET=rux-storage
R2_ACCOUNT_ID=xxxxx
R2_ACCESS_KEY_ID=xxxxx
R2_SECRET_ACCESS_KEY=xxxxx

# AWS S3 (alternative to R2)
AWS_ACCESS_KEY_ID=xxxxx
AWS_SECRET_ACCESS_KEY=xxxxx
AWS_REGION=us-east-1

# ===========================================
# Admin & Maintenance
# ===========================================

MAINTENANCE_MODE=false
ADMIN_EMAILS=admin@example.com

# ===========================================
# Proxy Services (Optional - for generated apps)
# ===========================================

# AI Models
OPENAI_API_KEY=sk-xxxxx
GOOGLE_AI_API_KEY=xxxxx
GROQ_API_KEY=gsk_xxxxx
COHERE_API_KEY=xxxxx
MISTRAL_API_KEY=xxxxx
PERPLEXITY_API_KEY=pplx-xxxxx

# Image Generation
STABILITY_API_KEY=sk-xxxxx
MIDJOURNEY_API_KEY=xxxxx

# Communication
SENDGRID_API_KEY=SG.xxxxx
SENDGRID_DEFAULT_SENDER=noreply@yourdomain.com
RESEND_API_KEY=re_xxxxx
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_API_KEY=SKxxxxx
TWILIO_API_SECRET=xxxxx
TWILIO_TWIML_APP_SID=APxxxxx

# Maps & Search
GOOGLE_MAPS_API_KEY=xxxxx
GOOGLE_SEARCH_API_KEY=xxxxx
GOOGLE_SEARCH_ENGINE_ID=xxxxx
GOOGLE_TRANSLATE_API_KEY=xxxxx
SERP_API_KEY=xxxxx

# Content APIs
NEWS_API_KEY=xxxxx
ALPHA_VANTAGE_API_KEY=xxxxx
TMDB_API_KEY=xxxxx
OPENWEATHER_API_KEY=xxxxx

# Validation
ABSTRACT_API_KEY=xxxxx

# ===========================================
# Production Notes:
# ===========================================
# 1. Never commit real credentials to version control
# 2. Use strong, unique values for all secrets
# 3. Generate ENCRYPTION_MASTER_KEY with: openssl rand -base64 32
# 4. Generate HASH_SALT with: openssl rand -base64 32
# 5. Configure Stripe webhook endpoint in dashboard
# 6. Set up Supabase database migrations
# ===========================================
# Fallback model when codex-* is unavailable (optional)
CODEX_MODEL_FALLBACK=""
