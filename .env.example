# ===========================================
# RUX - AI-Powered Mobile App Generator
# Environment Configuration
# ===========================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/rux?schema=public"

# Clerk Authentication
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxx

# AI API Keys
# xAI Grok - Get from https://x.ai/api
XAI_API_KEY=xai-xxxxx

# Anthropic Claude - Get from https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-xxxxx

# Upstash Redis (Rate Limiting)
# Get from https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxx

# Encryption
# Generate with: openssl rand -base64 32
ENCRYPTION_MASTER_KEY=your-32-character-or-longer-secret-key-here
HASH_SALT=rux-hash-salt-change-in-production

# Expo / EAS Build
# Get from https://expo.dev/accounts/[account]/settings/access-tokens
EAS_ACCESS_TOKEN=xxxxx
EXPO_PROJECT_ID=xxxxx

# GitHub OAuth (optional, for GitHub integration)
# Create at https://github.com/settings/developers
GITHUB_CLIENT_ID=xxxxx
GITHUB_CLIENT_SECRET=xxxxx

# Stripe (Payments)
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Stripe Price IDs (create products in Stripe Dashboard)
STRIPE_PRO_PRICE_ID=price_xxxxx
STRIPE_ELITE_PRICE_ID=price_xxxxx

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Maintenance Mode (set to "true" to enable)
MAINTENANCE_MODE=false

# Admin emails that can bypass maintenance mode (comma-separated)
ADMIN_EMAILS=nick@rux.sh

# ===========================================
# Proxy Services (Managed API Access)
# Users can access these services through /api/proxy
# without exposing their own API keys
# ===========================================

# ============================================
# AI MODELS (Required - at least one)
# ============================================

# xAI Grok - Primary/Default AI (RECOMMENDED)
# Get from https://x.ai/api
# Already defined above, reused here
# XAI_API_KEY=xai-xxxxx

# OpenAI - GPT-4, GPT-4o, DALL-E, Whisper, TTS
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxx

# Anthropic Claude - Alternative to Grok
# Get from https://console.anthropic.com
# Already defined above as CLAUDE_API_KEY

# Google AI - Gemini models
# Get from https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY=xxxxx

# Groq - Fast inference
# Get from https://console.groq.com
GROQ_API_KEY=gsk_xxxxx

# Cohere - Command models
# Get from https://dashboard.cohere.com/api-keys
COHERE_API_KEY=xxxxx

# Mistral AI
# Get from https://console.mistral.ai
MISTRAL_API_KEY=xxxxx

# Perplexity - Search-augmented AI
# Get from https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-xxxxx

# ============================================
# IMAGE GENERATION
# ============================================

# Stability AI - Stable Diffusion
# Get from https://platform.stability.ai/account/keys
STABILITY_API_KEY=sk-xxxxx

# Midjourney API (via third-party)
MIDJOURNEY_API_KEY=xxxxx

# ============================================
# SEARCH & DATA
# ============================================

# Google Custom Search - Web search
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_SEARCH_API_KEY=xxxxx
GOOGLE_SEARCH_ENGINE_ID=xxxxx

# Google Maps - Maps, geocoding, places
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=xxxxx

# Google Translate
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_TRANSLATE_API_KEY=xxxxx

# SERP API - Alternative search API
# Get from https://serpapi.com/manage-api-key
SERP_API_KEY=xxxxx

# ============================================
# COMMUNICATION
# ============================================

# SendGrid - Email
# Get from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxx
SENDGRID_DEFAULT_SENDER=noreply@yourdomain.com

# Resend - Alternative email service
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxx

# Twilio - SMS and WhatsApp
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+1234567890

# Push Notifications (Firebase)
# Get from https://console.firebase.google.com
FIREBASE_SERVER_KEY=xxxxx

# ============================================
# MEDIA PROCESSING
# ============================================

# All handled by OpenAI (Whisper, TTS) - see OPENAI_API_KEY above

# ============================================
# DATA & UTILITIES
# ============================================

# Weather - OpenWeatherMap
# Get from https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=xxxxx

# Storage - File uploads
STORAGE_PROVIDER=local
STORAGE_BUCKET=rux-storage

# AWS S3 (if using s3 provider)
AWS_ACCESS_KEY_ID=xxxxx
AWS_SECRET_ACCESS_KEY=xxxxx
AWS_REGION=us-east-1

# Cloudflare R2 (if using r2 provider)
R2_ACCOUNT_ID=xxxxx
R2_ACCESS_KEY_ID=xxxxx
R2_SECRET_ACCESS_KEY=xxxxx

# ============================================
# CONTENT APIS
# ============================================

# News API
# Get from https://newsapi.org/account
NEWS_API_KEY=xxxxx

# Alpha Vantage - Stock market data
# Get from https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=xxxxx

# CoinGecko API (crypto) - Free, no key needed
# Pro tier: https://www.coingecko.com/en/api/pricing

# TMDB - Movies and TV shows
# Get from https://www.themoviedb.org/settings/api
TMDB_API_KEY=xxxxx

# ============================================
# VALIDATION & VERIFICATION
# ============================================

# Abstract API - Email/phone validation, IP geolocation
# Get from https://www.abstractapi.com
ABSTRACT_API_KEY=xxxxx

# ===========================================
# Production Notes:
# ===========================================
# 1. Never commit real credentials to version control
# 2. Use strong, unique values for all secrets
# 3. Enable HTTPS in production
# 4. Set up proper CORS policies
# 5. Configure Clerk webhook endpoints
# 6. Set up database backups
# ===========================================
