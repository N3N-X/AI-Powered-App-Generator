# ===========================================
# RUX - AI-Powered Mobile App Generator
# Environment Configuration
# ===========================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/rux?schema=public"

# Clerk Authentication
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxx

# Clerk URLs (optional, defaults work for most cases)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# AI API Keys
# xAI Grok - Get from https://x.ai/api
XAI_API_KEY=xai-xxxxx

# Anthropic Claude - Get from https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-xxxxx

# Upstash Redis (Rate Limiting)
# Get from https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxx

# Encryption
# Generate with: openssl rand -base64 32
ENCRYPTION_MASTER_KEY=your-32-character-or-longer-secret-key-here
HASH_SALT=rux-hash-salt-change-in-production

# Expo / EAS Build
# Get from https://expo.dev/accounts/[account]/settings/access-tokens
EAS_ACCESS_TOKEN=xxxxx
EXPO_PROJECT_ID=xxxxx

# GitHub OAuth (optional, for GitHub integration)
# Create at https://github.com/settings/developers
GITHUB_CLIENT_ID=xxxxx
GITHUB_CLIENT_SECRET=xxxxx

# Stripe (Payments)
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Stripe Price IDs (create products in Stripe Dashboard)
STRIPE_PRO_PRICE_ID=price_xxxxx
STRIPE_ELITE_PRICE_ID=price_xxxxx

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ===========================================
# Production Notes:
# ===========================================
# 1. Never commit real credentials to version control
# 2. Use strong, unique values for all secrets
# 3. Enable HTTPS in production
# 4. Set up proper CORS policies
# 5. Configure Clerk webhook endpoints
# 6. Set up database backups
# ===========================================
