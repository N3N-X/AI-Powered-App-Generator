generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  ELITE
}

enum Role {
  USER
  ADMIN
}

enum Platform {
  WEB
  IOS
  ANDROID
}

enum BuildStatus {
  PENDING
  QUEUED
  BUILDING
  SUCCESS
  FAILED
  CANCELLED
}

enum BuildPlatform {
  ANDROID
  IOS
}

model User {
  id                    String    @id @default(cuid())
  clerkId               String    @unique
  email                 String    @unique
  name                  String?
  avatarUrl             String?
  plan                  Plan      @default(FREE)
  role                  Role      @default(USER)

  // Stripe billing
  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?   @unique

  // Encrypted credentials
  githubTokenEncrypted  String?
  claudeKeyEncrypted    String?

  // Credit system (replaces daily prompts)
  credits               Int       @default(3000)  // Free tier starts with 3k
  totalCreditsUsed      Int       @default(0)
  lastCreditReset       DateTime?                 // For monthly reset on paid plans

  // Timestamps
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  projects              Project[]
  credentials           DeveloperCredential[]
  builds                Build[]
  promptHistory         PromptHistory[]
  tokenPurchases        TokenPurchase[]

  @@index([clerkId])
  @@index([email])
  @@index([stripeCustomerId])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  slug        String
  platform    Platform @default(WEB)

  // Code storage - JSONB for flexible file structure
  codeFiles   Json     @default("{}") // { "App.tsx": "...", "screens/Home.tsx": "..." }

  // App configuration
  appConfig   Json?    // { "name": "...", "version": "...", "expo": {...} }

  // GitHub integration
  githubRepo  String?
  githubUrl   String?

  // Domain settings (WEB platform only)
  subdomain       String?   @unique  // e.g., "myapp" -> myapp.rux.sh
  customDomain    String?   @unique  // e.g., "myapp.com"
  domainVerified  Boolean   @default(false)  // Custom domain verified via DNS

  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  builds      Build[]
  prompts     PromptHistory[]
  apiKeys     ProjectApiKey[]

  @@unique([userId, slug])
  @@index([userId])
  @@index([subdomain])
  @@index([customDomain])
}

model PromptHistory {
  id          String   @id @default(cuid())
  prompt      String   @db.Text
  response    String?  @db.Text
  model       String   // "grok" or "claude"
  tokens      Int?

  // Timestamps
  createdAt   DateTime @default(now())

  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([createdAt])
}

model DeveloperCredential {
  id            String   @id @default(cuid())
  platform      String   // "apple", "google", "expo"
  name          String   // Display name for the credential

  // All sensitive data encrypted with user's key
  encryptedData String   @db.Text // JSON: { keyId, issuerId, p8Key } for Apple, etc.

  // Metadata (non-sensitive)
  metadata      Json?    // { teamId, bundleId, etc. }

  // Verification status
  verified      Boolean  @default(false)
  lastVerified  DateTime?

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform, name])
  @@index([userId])
}

model Build {
  id            String        @id @default(cuid())
  platform      BuildPlatform
  status        BuildStatus   @default(PENDING)

  // EAS Build info
  easBuildId    String?       @unique
  buildUrl      String?
  artifactUrl   String?

  // Build configuration
  buildProfile  String        @default("production") // "development", "preview", "production"
  version       String?
  buildNumber   Int?

  // Logs and errors
  logs          String?       @db.Text
  errorMessage  String?

  // Timing
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId     String
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([easBuildId])
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?  // Where they signed up from
  createdAt DateTime @default(now())

  @@index([email])
}

// ============================================
// Proxy System - Managed API Access
// ============================================

enum ProxyService {
  // AI Models
  XAI           // Grok - Primary AI
  OPENAI        // GPT-4, GPT-4o
  ANTHROPIC     // Claude
  GOOGLE_AI     // Gemini
  GROQ          // Fast inference
  COHERE        // Command models
  MISTRAL       // Mistral models
  PERPLEXITY    // Search-augmented AI

  // Image Generation
  DALL_E        // OpenAI DALL-E 3
  STABLE_DIFFUSION  // Stability AI
  MIDJOURNEY    // Midjourney API
  FLUX          // Flux models

  // Search & Data
  GOOGLE_SEARCH // Web search
  IMAGE_SEARCH  // Image search
  PLACES        // Google Places
  MAPS          // Maps & directions
  SERP          // SERP API

  // Media Processing
  TRANSCRIBE    // Audio transcription (Whisper)
  TTS           // Text-to-speech
  VIDEO         // Video processing
  PDF           // PDF generation
  OCR           // Optical character recognition

  // Communication
  EMAIL         // Resend/SendGrid
  SMS           // Twilio
  PUSH          // Push notifications
  WHATSAPP      // WhatsApp Business

  // Data & Utilities
  STORAGE       // File storage (R2/S3)
  DATABASE      // Generic database proxy for any data
  APP_AUTH      // User authentication for generated apps
  ANALYTICS     // Event tracking
  QR_CODE       // QR generation
  WEATHER       // Weather data
  TRANSLATE     // Translation
  CURRENCY      // Currency conversion

  // Validation & Verification
  EMAIL_VALIDATE  // Email verification
  PHONE_VALIDATE  // Phone validation
  DOMAIN_WHOIS    // Domain lookup

  // Payments
  PAYMENTS        // Stripe payments, subscriptions, in-app purchases

  // Content APIs
  NEWS          // News API
  STOCKS        // Stock market data
  CRYPTO        // Cryptocurrency data
  MOVIES        // Movies/TV data (TMDB)
  BOOKS         // Book search
  SPORTS        // Sports data
}

model ProjectApiKey {
  id           String   @id @default(cuid())
  name         String   @default("Default")
  keyHash      String   @unique // Hashed API key for lookup
  keyPrefix    String   // First 8 chars for display (rux_xxx...)
  keyEncrypted String?  // Encrypted raw key for injection into generated code

  // Permissions
  services    ProxyService[] // Which services this key can access

  // Rate limits (overrides plan defaults if set)
  rateLimit   Int?     // Requests per minute

  // Status
  active      Boolean  @default(true)
  lastUsedAt  DateTime?

  // Timestamps
  createdAt   DateTime @default(now())
  expiresAt   DateTime?

  // Relations
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  usageRecords ProxyUsage[]

  @@index([keyHash])
  @@index([projectId])
}

model ProxyUsage {
  id          String       @id @default(cuid())
  service     ProxyService
  operation   String       // e.g., "chat.completions", "geocode", "send"

  // Usage metrics
  creditsUsed Int
  requestSize Int?         // Bytes
  responseSize Int?        // Bytes
  latencyMs   Int?

  // Request metadata
  metadata    Json?        // Service-specific data (tokens, recipients, etc.)

  // Status
  success     Boolean
  errorCode   String?

  // Timestamps
  createdAt   DateTime     @default(now())

  // Relations
  apiKeyId    String
  apiKey      ProjectApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  projectId   String
  userId      String

  @@index([projectId, createdAt])
  @@index([userId, createdAt])
  @@index([service, createdAt])
  @@index([apiKeyId])
}

model ProxyCredits {
  id              String   @id @default(cuid())

  // Credits balance
  balance         Int      @default(0)
  monthlyAllotment Int     @default(0)

  // Billing period
  periodStart     DateTime @default(now())
  periodEnd       DateTime

  // Overage tracking
  overageCredits  Int      @default(0)
  overageRate     Float    @default(0.001) // $ per credit

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  userId          String   @unique

  @@index([userId])
  @@index([periodEnd])
}

model StorageFile {
  id          String   @id @default(cuid())
  filename    String
  contentType String
  size        Int      // Bytes

  // Storage location
  bucket      String   @default("rux-storage")
  key         String   // S3/R2 object key
  url         String?  // Public URL if accessible

  // Access control
  isPublic    Boolean  @default(false)

  // Timestamps
  createdAt   DateTime @default(now())
  deletedAt   DateTime?

  // Relations
  projectId   String
  userId      String

  @@unique([bucket, key])
  @@index([projectId])
  @@index([userId])
}

// ============================================
// Generic Database Proxy - Stores any data for generated apps
// ============================================

model AppCollection {
  id          String   @id @default(cuid())
  name        String   // Collection name (e.g., "bookings", "todos", "products")

  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  projectId   String
  documents   AppDocument[]

  @@unique([projectId, name])
  @@index([projectId])
}

model AppDocument {
  id          String   @id @default(cuid())
  data        Json     // The actual document data (any structure)

  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  collectionId String
  collection   AppCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([collectionId])
  @@index([collectionId, createdAt])
}

// ============================================
// App User Authentication - Users of generated apps
// ============================================

model AppUser {
  id            String   @id @default(cuid())
  email         String
  passwordHash  String   // bcrypt hashed password
  name          String?
  avatarUrl     String?
  metadata      Json?    // Any additional user data

  // Email verification
  emailVerified Boolean  @default(false)
  verifyToken   String?

  // Password reset
  resetToken    String?
  resetExpires  DateTime?

  // Status
  active        Boolean  @default(true)
  lastLoginAt   DateTime?

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  projectId     String
  sessions      AppSession[]

  @@unique([projectId, email])
  @@index([projectId])
  @@index([email])
  @@index([verifyToken])
  @@index([resetToken])
}

model AppSession {
  id          String   @id @default(cuid())
  token       String   @unique // Session token (hashed)
  userAgent   String?
  ipAddress   String?

  // Expiration
  expiresAt   DateTime

  // Timestamps
  createdAt   DateTime @default(now())
  lastActiveAt DateTime @default(now())

  // Relations
  appUserId   String
  appUser     AppUser  @relation(fields: [appUserId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([appUserId])
  @@index([expiresAt])
}

// ============================================
// Token Purchase System (One-time purchases)
// ============================================

model TokenPurchase {
  id                String   @id @default(cuid())

  // Purchase details
  credits           Int      // Number of credits purchased
  amountPaid        Int      // Amount paid in cents
  currency          String   @default("usd")

  // Stripe payment info
  stripePaymentIntentId String? @unique
  stripeChargeId        String?

  // Status
  status            String   @default("completed") // "completed", "refunded", "failed"

  // Timestamps
  createdAt         DateTime @default(now())
  refundedAt        DateTime?

  // Relations
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([stripePaymentIntentId])
}
