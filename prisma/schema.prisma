generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppCollection {
  id          String        @id
  name        String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  projectId   String
  AppDocument AppDocument[]

  @@unique([projectId, name])
  @@index([projectId])
}

model AppDocument {
  id            String        @id
  data          Json
  createdAt     DateTime      @default(now())
  updatedAt     DateTime
  collectionId  String
  AppCollection AppCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([collectionId, createdAt])
  @@index([collectionId])
}

model AppSession {
  id           String   @id
  token        String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())
  appUserId    String
  AppUser      AppUser  @relation(fields: [appUserId], references: [id], onDelete: Cascade)

  @@index([appUserId])
  @@index([expiresAt])
  @@index([token])
}

model AppUser {
  id            String       @id
  email         String
  passwordHash  String
  name          String?
  avatarUrl     String?
  metadata      Json?
  emailVerified Boolean      @default(false)
  verifyToken   String?
  resetToken    String?
  resetExpires  DateTime?
  active        Boolean      @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime
  projectId     String
  AppSession    AppSession[]

  @@unique([projectId, email])
  @@index([email])
  @@index([projectId])
  @@index([resetToken])
  @@index([verifyToken])
}

model Build {
  id           String        @id
  platform     BuildPlatform
  status       BuildStatus   @default(PENDING)
  easBuildId   String?       @unique
  buildUrl     String?
  artifactUrl  String?
  buildProfile String        @default("production")
  version      String?
  buildNumber  Int?
  logs         String?
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime
  userId       String
  projectId    String
  Project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  User         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([easBuildId])
  @@index([projectId])
  @@index([status])
  @@index([userId])
}

model DeveloperCredential {
  id            String    @id
  platform      String
  name          String
  encryptedData String
  metadata      Json?
  verified      Boolean   @default(false)
  lastVerified  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  userId        String
  User          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform, name])
  @@index([userId])
}

model Project {
  id             String          @id
  name           String
  description    String?
  slug           String
  platform       Platform        @default(WEB)
  codeFiles      Json            @default("{}")
  appConfig      Json?
  githubRepo     String?
  githubUrl      String?
  subdomain      String?         @unique
  customDomain   String?         @unique
  domainVerified Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime
  userId         String
  Build          Build[]
  User           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  ProjectApiKey  ProjectApiKey[]
  PromptHistory  PromptHistory[]

  @@unique([userId, slug])
  @@index([customDomain])
  @@index([subdomain])
  @@index([userId])
}

model ProjectApiKey {
  id           String         @id
  name         String         @default("Default")
  keyHash      String         @unique
  keyPrefix    String
  services     ProxyService[]
  rateLimit    Int?
  active       Boolean        @default(true)
  lastUsedAt   DateTime?
  createdAt    DateTime       @default(now())
  expiresAt    DateTime?
  projectId    String
  keyEncrypted String?
  Project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ProxyUsage   ProxyUsage[]

  @@index([keyHash])
  @@index([projectId])
}

model PromptHistory {
  id        String   @id
  prompt    String
  response  String?
  model     String
  tokens    Int?
  createdAt DateTime @default(now())
  userId    String
  projectId String
  Project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([projectId])
  @@index([userId])
}

model ProxyCredits {
  id               String   @id
  balance          Int      @default(0)
  monthlyAllotment Int      @default(0)
  periodStart      DateTime @default(now())
  periodEnd        DateTime
  overageCredits   Int      @default(0)
  overageRate      Float    @default(0.001)
  createdAt        DateTime @default(now())
  updatedAt        DateTime
  userId           String   @unique

  @@index([periodEnd])
  @@index([userId])
}

model ProxyUsage {
  id            String        @id
  service       ProxyService
  operation     String
  creditsUsed   Int
  requestSize   Int?
  responseSize  Int?
  latencyMs     Int?
  metadata      Json?
  success       Boolean
  errorCode     String?
  createdAt     DateTime      @default(now())
  apiKeyId      String
  projectId     String
  userId        String
  ProjectApiKey ProjectApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId])
  @@index([projectId, createdAt])
  @@index([service, createdAt])
  @@index([userId, createdAt])
}

model StorageFile {
  id          String    @id
  filename    String
  contentType String
  size        Int
  bucket      String    @default("rux-storage")
  key         String
  url         String?
  isPublic    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?
  projectId   String
  userId      String

  @@unique([bucket, key])
  @@index([projectId])
  @@index([userId])
}

model TokenPurchase {
  id                    String    @id
  credits               Int
  amountPaid            Int
  currency              String    @default("usd")
  stripePaymentIntentId String?   @unique
  stripeChargeId        String?
  status                String    @default("completed")
  createdAt             DateTime  @default(now())
  refundedAt            DateTime?
  userId                String
  User                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripePaymentIntentId])
  @@index([userId, createdAt])
}

model User {
  id                   String                @id
  clerkId              String                @unique
  email                String                @unique
  name                 String?
  avatarUrl            String?
  plan                 Plan                  @default(FREE)
  role                 Role                  @default(USER)
  stripeCustomerId     String?               @unique
  stripeSubscriptionId String?               @unique
  githubTokenEncrypted String?
  claudeKeyEncrypted   String?
  credits              Int                   @default(3000)
  totalCreditsUsed     Int                   @default(0)
  lastCreditReset      DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime
  Build                Build[]
  DeveloperCredential  DeveloperCredential[]
  Project              Project[]
  PromptHistory        PromptHistory[]
  TokenPurchase        TokenPurchase[]

  @@index([clerkId])
  @@index([email])
  @@index([stripeCustomerId])
}

model WaitlistEntry {
  id        String   @id
  email     String   @unique
  source    String?
  createdAt DateTime @default(now())

  @@index([email])
}

enum BuildPlatform {
  ANDROID
  IOS
}

enum BuildStatus {
  PENDING
  QUEUED
  BUILDING
  SUCCESS
  FAILED
  CANCELLED
}

enum Plan {
  FREE
  PRO
  ELITE
}

enum Platform {
  WEB
  IOS
  ANDROID
}

enum ProxyService {
  XAI
  OPENAI
  ANTHROPIC
  GOOGLE_AI
  GROQ
  COHERE
  MISTRAL
  PERPLEXITY
  DALL_E
  STABLE_DIFFUSION
  MIDJOURNEY
  FLUX
  GOOGLE_SEARCH
  IMAGE_SEARCH
  PLACES
  MAPS
  SERP
  TRANSCRIBE
  TTS
  VIDEO
  PDF
  OCR
  EMAIL
  SMS
  PUSH
  WHATSAPP
  STORAGE
  DATABASE
  ANALYTICS
  QR_CODE
  WEATHER
  TRANSLATE
  CURRENCY
  EMAIL_VALIDATE
  PHONE_VALIDATE
  DOMAIN_WHOIS
  NEWS
  STOCKS
  CRYPTO
  MOVIES
  BOOKS
  SPORTS
  APP_AUTH
  PAYMENTS
}

enum Role {
  USER
  ADMIN
}
